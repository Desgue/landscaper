# Greenprint Backend Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: Google AI Studio API key for Gemini image generation
GEMINI_API_KEY=

# Optional: Gemini model ID (default: gemini-3.1-flash-image-preview)
# GEMINI_MODEL=gemini-3.1-flash-image-preview

# Optional: HTTP listen port (default: 8080)
# PORT=8080
